---
import type { CollectionEntry } from "astro:content";
import { mapEmbedUrl } from "../data/site";
import { collectionsOrder } from "../data/collectionsOrder";

interface Props {
  collections: CollectionEntry<"collections">[];
}

const { collections } = Astro.props;
const orderMap = new Map(collectionsOrder.map((slug, i) => [slug, i]));
const sorted = [...collections].sort((a, b) => {
  const ia = orderMap.get(a.id) ?? 9999;
  const ib = orderMap.get(b.id) ?? 9999;
  return ia - ib;
});
---

<section id="map" class="py-20">
  <div class="container mx-auto max-w-5xl px-4">
    <h2 class="mb-12 text-center text-3xl font-bold tracking-tight">
      作品地圖
    </h2>

    <!-- Embedded Google My Maps -->
    <div class="mb-12 overflow-hidden rounded-xl border shadow-sm">
      <iframe
        src={mapEmbedUrl}
        width="100%"
        height="480"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="作品分佈地圖"></iframe>
    </div>

    <!-- Collections List -->
    <div class="overflow-x-auto rounded-xl border">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b bg-muted/50">
            <th class="px-4 py-3 text-left font-medium">作品名稱</th>
            <th class="px-4 py-3 text-center font-medium">件數</th>
            <th class="px-4 py-3 text-left font-medium">地點</th>
          </tr>
        </thead>
        <tbody>
          {
            sorted.map((col, i) => {
              const pieces = col.data.works.length;
              return (
                <tr
                  class:list={[
                    "border-b last:border-0 transition-colors hover:bg-muted/30",
                    i % 2 === 0 && "bg-muted/10",
                  ]}
                >
                  <td class="px-4 py-3 font-medium">{col.data.title}</td>
                  <td class="px-4 py-3 text-center">{pieces}</td>
                  <td class="px-4 py-3">
                    {col.data.locationUrl &&
                    col.data.locationUrl.startsWith("http") ? (
                      <a
                        href={col.data.locationUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 text-primary underline-offset-4 hover:underline"
                      >
                        {col.data.location || "查看地圖"}
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="h-3.5 w-3.5"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                          <polyline points="15 3 21 3 21 9" />
                          <line x1="10" x2="21" y1="14" y2="3" />
                        </svg>
                      </a>
                    ) : (
                      <span class="text-muted-foreground">
                        {col.data.location || "-"}
                      </span>
                    )}
                  </td>
                </tr>
              );
            })
          }
        </tbody>
      </table>
    </div>
  </div>
</section>
