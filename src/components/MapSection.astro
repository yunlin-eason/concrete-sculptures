---
import type { CollectionEntry } from "astro:content";
import { mapEmbedUrl } from "../data/site";
import { collectionsOrder } from "../data/collectionsOrder";
import { WorksTable } from "./WorksTable";

interface Props {
  collections: CollectionEntry<"collections">[];
}

const { collections } = Astro.props;
const orderMap = new Map(collectionsOrder.map((slug, i) => [slug, i]));
const sorted = [...collections].sort((a, b) => {
  const ia = orderMap.get(a.id) ?? 9999;
  const ib = orderMap.get(b.id) ?? 9999;
  return ia - ib;
});

// Serialize for the React component
const tableData = sorted.map((col) => ({
  slug: col.id,
  title: col.data.title,
  location: col.data.location ?? "",
  locationUrl: col.data.locationUrl ?? "",
  works: col.data.works.map((w) => ({
    slug: w.slug,
    title: w.title ?? w.slug,
    locationUrl: w.locationUrl,
  })),
}));

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<section id="map" class="py-20">
  <div class="container mx-auto max-w-5xl px-4">
    <h2 class="mb-12 text-center text-3xl font-bold tracking-tight">
      作品地圖
    </h2>

    <!-- Embedded Google My Maps -->
    <div class="mb-12 overflow-hidden rounded-xl border shadow-sm">
      <iframe
        src={mapEmbedUrl}
        width="100%"
        height="480"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="作品分佈地圖"></iframe>
    </div>

    <!-- Collections List (interactive React component) -->
    <WorksTable collections={tableData} base={base} client:visible />
  </div>
</section>
