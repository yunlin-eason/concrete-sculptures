---
import { collectionsOrder } from "@/data/collectionsOrder";
import { CollectionCard } from "./CollectionCard";
import { getWorkCover, detectWorkSlugs } from "@/lib/images";

import type { CollectionEntry } from "astro:content";
interface Props {
  collections: CollectionEntry<"collections">[];
}
const { collections } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const orderMap = new Map(collectionsOrder.map((slug, i) => [slug, i]));
const sorted = [...collections].sort((a, b) => {
  const ia = orderMap.get(a.id) ?? 9999;
  const ib = orderMap.get(b.id) ?? 9999;
  return ia - ib;
});

// Pre-compute covers + positions for each collection
const collectionsWithCovers = sorted.map((col) => {
  let workSlugs = col.data.works.map((w) => w.slug);
  if (workSlugs.length === 0) workSlugs = detectWorkSlugs(col.id);
  if (workSlugs.length === 0) workSlugs = [col.id];
  const paired = workSlugs
    .map((ws) => {
      const cover = getWorkCover(col.id, ws);
      const work = col.data.works.find((w) => w.slug === ws);
      const position = work?.coverPosition ?? { x: 50, y: 50 };
      return cover ? { cover, position } : null;
    })
    .filter(Boolean) as { cover: string; position: { x: number; y: number } }[];
  return {
    collection: col,
    covers: paired.map((p) => p.cover),
    coverPositions: paired.map((p) => p.position),
    worksCount: workSlugs.length,
  };
});
---

<section id="works" class="bg-muted/40 py-20">
  <div class="container mx-auto max-w-5xl px-4">
    <h2 class="mb-12 text-center text-3xl font-bold tracking-tight">作品集</h2>
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        collectionsWithCovers.map(({ collection: col, covers, coverPositions, worksCount }) => (
          <CollectionCard
            client:visible
            title={col.data.title}
            covers={covers}
            coverPositions={coverPositions}
            href={`${base}collections/${col.id}/`}
            base={base}
            worksCount={worksCount}
            location={col.data.location}
            excerpt={col.data.excerpt}
          />
        ))
      }
    </div>
  </div>
</section>
